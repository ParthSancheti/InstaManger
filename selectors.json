{
  "_comment": "Host this on GitHub, put the Raw URL in SELECTOR_URL inside extension/background.js. Only include keys you want to OVERRIDE — everything else falls back to the built-in defaults in content.js. Prefix XPath entries with 'xpath:' (or start them with //). First matching candidate wins.",

  "chatgpt": {
    "input": [
      "#prompt-textarea",
      "div.ProseMirror[contenteditable=\"true\"]",
      "p[data-placeholder=\"Ask anything\"]"
    ],
    "send": [
      "button[data-testid=\"send-button\"]",
      "button[aria-label=\"Send prompt\"]"
    ],
    "generatedImage": [
      "img[alt^=\"Generated image\"]",
      "img[src*=\"backend-api/estuary/content\"]"
    ]
  },

  "claude": {
    "downloadButton": [
      "xpath://button[.//span[normalize-space(text())=\"Download\"]]",
      "xpath://a[.//span[normalize-space(text())=\"Download\"]]"
    ],
    "skipButton": [
      "xpath://button[.//span[normalize-space(text())=\"Skip\"]]",
      "xpath://*[self::button or self::a][normalize-space(.)=\"Skip\"]"
    ]
  },

  "gemini": {
    "input": [
      "div.ql-editor[contenteditable=\"true\"]"
    ],
    "send": [
      "xpath://button[.//mat-icon[@fonticon=\"arrow_upward\"]]"
    ],
    "attachment": [
      "uploader-file-preview",
      "[data-test-id=\"file-preview\"]",
      "xpath://div[contains(@class,\"file-preview\")]"
    ]
  },

  "flow": {
    "newProject": [
      "xpath://button[contains(., \"New project\")]",
      "xpath://button[contains(., \"Start\")]"
    ],
    "input": [
      "div[data-slate-editor=\"true\"][contenteditable=\"true\"]"
    ],
    "create": [
      "xpath://button[.//i[normalize-space(text())=\"arrow_forward\"]]"
    ],
    "videoThumbs": [
      "img[src*=\"MEDIA_URL_TYPE_THUMBNAIL\"]"
    ],
    "download": [
      "xpath://button[.//i[contains(text(),\"download\")]]"
    ]
  },

  "elevenlabs": {
    "voicePanelToggle": [
      "xpath://label[normalize-space(text())=\"Voice\"]/following-sibling::div//button",
      "button[data-testid=\"tts-voice-selector\"]",
      "xpath://button[contains(@aria-label, \"Select voice\")]"
    ],
    "exploreTab": [
      "[data-testid=\"tabbed-voice-selector-explore-tab\"]",
      "xpath://button[@role=\"tab\" and contains(., \"Explore\")]"
    ],
    "voiceSearch": [
      "input[placeholder=\"Start typing to search...\"]",
      "input[data-agent-id^=\"search-bar\"]"
    ],
    "voiceResult": [
      "li.eleven-list-item button[data-type=\"list-item-trigger-overlay\"]",
      "xpath:(//li[contains(@class, \"eleven-list-item\")])[1]//button"
    ],
    "modelSelector": [
      "[data-testid=\"tts-model-selector\"]"
    ],
    "modelV3": [
      "xpath://div[contains(@class, \"border rounded-xl\") and contains(., \"Eleven v3\")]",
      "xpath://p[normalize-space(text())=\"Eleven v3\"]/ancestor::div[contains(@class, \"border\")][1]"
    ],
    "input": [
      "[data-testid=\"tts-editor\"] div[contenteditable=\"true\"]",
      "[data-testid=\"tts-editor\"] [role=\"textbox\"]",
      "[data-testid=\"tts-editor\"] div[data-node-view-content-react]"
    ],
    "generate": [
      "[data-testid=\"tts-generate\"]"
    ],
    "download": [
      "xpath:(//button[@aria-label=\"Download\"])[1]",
      "xpath:(//button[.//svg[contains(@viewBox, \"0 0 18 18\")]])[1]"
    ],
    "generating": [
      "xpath://button[@data-testid=\"tts-generate\" and @data-loading=\"true\"]"
    ]
  }
}
